{
  "name": "novelist",
  "version": "0.1.0",
  "private": true,
  "description": "A local markdown editor for Chromium-based browsers.",
  "scripts": {
    "build": "node scripts/build.js",
    "serve": "node scripts/serve.js",
    "typecheck": "tsc --noEmit",
    "check": "npm run build && npm run typecheck && npm run test && playwright test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:gui": "npm run build && playwright test",
    "test:all": "npm run build && npm run test:coverage && playwright test"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "@material/web": "^2.4.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "codemirror": "^6.0.2",
    "esbuild": "^0.28.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.7.2",
    "@vitest/coverage-v8": "^4.1.3",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "vitest": "^4.1.3"
  }
}
